# Required
SESSION_SECRET=replace-with-32-plus-random-characters
ACCESS_CODE=replace-with-your-login-passphrase
VESTABOARD_API_TOKEN=replace-with-your-vestaboard-rw-api-key

# Optional
CRON_SECRET=replace-with-a-random-secret-for-workflow-scheduling
GEMMA_API_KEY=replace-with-your-google-ai-studio-api-key

# Cookie security — explicit override (optional).
# Defaults: secure=false in development, secure=true in production (NODE_ENV=production).
# The launchers (run.sh / runWebApp.bat) automatically set SECURE_COOKIES=false so
# plain-HTTP localhost works without configuration. For HTTPS deployments this is
# already handled by the production default — no override needed.
# SECURE_COOKIES=false  # force off (e.g. production build tested over HTTP)
# SECURE_COOKIES=true   # force on  (e.g. HTTPS behind a proxy that strips NODE_ENV)
